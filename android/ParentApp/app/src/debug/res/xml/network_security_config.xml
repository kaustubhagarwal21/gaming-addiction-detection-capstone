<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG BUILDS ONLY. Permits plain HTTP to any host so a LAN dev server
  (e.g. http://192.168.1.x:5000) works during development. This file overrides
  src/main/res/xml/network_security_config.xml for the debug build type only;
  release/sideload APKs use the strict HTTPS-only main config.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
