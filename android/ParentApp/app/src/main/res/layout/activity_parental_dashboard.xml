<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorBackground"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorBackground"
            app:titleTextColor="@color/text_primary"
            app:titleTextAppearance="@style/TextAppearance.App.Title" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="32dp">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <!-- Observation banner -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E0F2FE"
                    app:strokeWidth="0dp"
                    app:contentPadding="14dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:id="@+id/tvObservationBanner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#0C4A6E"
                        android:text=""
                        android:visibility="gone" />
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ HERO RISK CARD ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_hero_gradient"
                        android:padding="28dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <View
                                android:id="@+id/riskIndicatorBar"
                                android:layout_width="40dp"
                                android:layout_height="4dp"
                                android:background="@color/risk_low" />

                            <TextView
                                android:id="@+id/tvChildName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your Child"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="14dp" />

                            <TextView
                                android:id="@+id/tvCurrentRisk"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="44sp"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="-0.02"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/tvRiskScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#DBE4FF"
                                android:textSize="18sp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#33FFFFFF"
                                android:layout_marginTop="20dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="16dp">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:id="@+id/tvWeeklyHours"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="—"
                                        android:textColor="#FFFFFF"
                                        android:textSize="20sp"
                                        android:fontFamily="sans-serif-medium" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Weekly hours"
                                        android:textColor="#DBE4FF"
                                        android:textSize="11sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:id="@+id/tvLateNight"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="—"
                                        android:textColor="#FFFFFF"
                                        android:textSize="20sp"
                                        android:fontFamily="sans-serif-medium" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Late-night sessions"
                                        android:textColor="#DBE4FF"
                                        android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ ANOMALY ALERT (NEW) ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAnomaly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/risk_medium_bg"
                    app:strokeWidth="0dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_warning"
                            android:padding="6dp"
                            android:background="#33FFFFFF" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="UNUSUAL ACTIVITY"
                                android:textColor="@color/risk_medium"
                                android:textSize="11sp"
                                android:letterSpacing="0.16"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvAnomalyMessage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.App.Body"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ ACTION GRID ════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAlerts"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Alerts"
                        app:icon="@drawable/ic_warning"
                        app:iconGravity="textStart"
                        app:iconSize="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRecommendations"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Tips"
                        app:icon="@drawable/ic_heart"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"
                        style="@style/Widget.App.Button.Tonal" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmotions"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Emotions"
                        style="@style/Widget.App.Button.Outlined" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChatAnalysis"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Chat"
                        style="@style/Widget.App.Button.Outlined" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWeeklyReport"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Report"
                        style="@style/Widget.App.Button.Outlined" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDownloadPdf"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Download PDF"
                        style="@style/Widget.App.Button.Outlined" />
                </LinearLayout>

                <!-- ════════════ TIME LIMIT SUGGESTION ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTimeLimitSuggestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="SUGGESTED LIMIT"
                                android:textAppearance="@style/TextAppearance.App.Label" />

                            <TextView
                                android:id="@+id/tvLimitUrgency"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:textSize="11sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:background="@drawable/bg_chip_medium" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSuggestedLimit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="32sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/colorPrimary"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:id="@+id/tvLimitReason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.BodySmall"
                            android:layout_marginTop="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSetLimit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"
                            android:text="Apply this limit" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ PEER COMPARISON ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPeerComparison"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PEER COMPARISON"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvPeerPercentile"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="44sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/colorPrimary"
                                android:letterSpacing="-0.02" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="th percentile"
                                android:textAppearance="@style/TextAppearance.App.BodySmall"
                                android:layout_marginStart="8dp"
                                android:layout_marginBottom="12dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvPeerMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.BodySmall"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ SLEEP IMPACT ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSleepImpact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SLEEP IMPACT"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tvLateNightPct"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="28sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/risk_medium" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Late-night days"
                                    android:textAppearance="@style/TextAppearance.App.Caption"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/divider" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tvSleepDisruption"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="28sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/risk_high" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Disruptions"
                                    android:textAppearance="@style/TextAppearance.App.Caption"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSleepMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.BodySmall"
                            android:layout_marginTop="14dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ EXPLAINABLE RISK ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRiskExplanation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WHY THIS RISK LEVEL"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <TextView
                            android:id="@+id/tvRiskExplanation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:lineSpacingExtra="6dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ HEALTHY STREAK ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStreak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_streak" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="HEALTHY GAMING STREAK"
                                android:textAppearance="@style/TextAppearance.App.Label" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="14dp">
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tvStreakCurrent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="28sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/success" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Current"
                                    android:textAppearance="@style/TextAppearance.App.Caption" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tvStreakBest"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="28sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/colorPrimary" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Best"
                                    android:textAppearance="@style/TextAppearance.App.Caption" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tvStreakTotal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="28sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/colorPrimary" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Healthy days"
                                    android:textAppearance="@style/TextAppearance.App.Caption" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ 14-DAY TREND ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14-DAY RISK TREND"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/lineChart"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ TOP GAMES ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOP GAMES PLAYED"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <TextView
                            android:id="@+id/tvTopGames"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:lineSpacingExtra="6dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════ TOP RECOMMENDATION ════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOP RECOMMENDATION"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <TextView
                            android:id="@+id/tvRecommendationPreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:layout_marginTop="12dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
