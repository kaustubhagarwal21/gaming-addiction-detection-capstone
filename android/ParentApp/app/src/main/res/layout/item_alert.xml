<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/cardStroke"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:contentPadding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAlertSeverity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_chip_high"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvAlertTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textAppearance="@style/TextAppearance.App.Caption" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAlertMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Alert message"
            android:textAppearance="@style/TextAppearance.App.Body" />

        <!-- Parent feedback: the only real label the model gets. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="@color/cardStroke" />

        <LinearLayout
            android:id="@+id/feedbackPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Was this assessment accurate?"
                android:textAppearance="@style/TextAppearance.App.Caption" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccurate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="✓ Accurate"
                    android:textSize="12sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="@color/risk_low"
                    android:textColor="@color/risk_low"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFalseAlarm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="✗ False alarm"
                    android:textSize="12sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="@color/risk_high"
                    android:textColor="@color/risk_high"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvFeedbackGiven"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Thanks — recorded"
            android:textAppearance="@style/TextAppearance.App.Caption"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
