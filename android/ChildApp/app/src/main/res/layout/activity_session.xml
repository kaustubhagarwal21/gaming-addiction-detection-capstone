<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorBackground"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorBackground"
            app:titleTextColor="@color/text_primary"
            app:titleTextAppearance="@style/TextAppearance.App.Title" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Shown briefly while a session is being ended -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- ════════════ ACTIVE SESSION ════════════ -->
            <LinearLayout
                android:id="@+id/layoutActiveSession"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_hero_gradient"
                        android:padding="32dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="#33FFFFFF"
                                android:padding="8dp"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp">

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/circle_dot" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LIVE"
                                    android:textColor="#FFFFFF"
                                    android:textSize="11sp"
                                    android:letterSpacing="0.12"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginStart="8dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvGameName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Game"
                                android:textColor="#FFFFFF"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="14dp" />

                            <TextView
                                android:id="@+id/tvTimer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00:00"
                                android:textSize="56sp"
                                android:fontFamily="sans-serif-light"
                                android:textColor="#FFFFFF"
                                android:layout_marginTop="12dp" />

                            <TextView
                                android:id="@+id/tvLiveRisk"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Monitoring…"
                                android:textColor="#E0D6FF"
                                android:textSize="14sp"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Status chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1dp"
                        app:contentPadding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_mic"
                                app:tint="@color/colorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Voice"
                                android:textAppearance="@style/TextAppearance.App.Label"
                                android:layout_marginTop="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active"
                                android:textColor="@color/success"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1dp"
                        app:contentPadding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_chat"
                                app:tint="@color/colorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chat"
                                android:textAppearance="@style/TextAppearance.App.Label"
                                android:layout_marginTop="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active"
                                android:textColor="@color/success"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1dp"
                        app:contentPadding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_monitor"
                                app:tint="@color/colorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Behavior"
                                android:textAppearance="@style/TextAppearance.App.Label"
                                android:layout_marginTop="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tracking"
                                android:textColor="@color/success"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEndSession"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:text="End Session"
                    android:textSize="16sp"
                    app:backgroundTint="@color/risk_high" />
            </LinearLayout>

            <!-- ════════════ RESULT ════════════ -->
            <LinearLayout
                android:id="@+id/layoutResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_hero_gradient"
                        android:padding="32dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/ic_check_circle"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SESSION COMPLETE"
                                android:textColor="#E0D6FF"
                                android:textSize="11sp"
                                android:letterSpacing="0.16"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="16dp" />

                            <TextView
                                android:id="@+id/tvRiskLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CASUAL"
                                android:textColor="#FFFFFF"
                                android:textSize="40sp"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="-0.01"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:id="@+id/tvRiskScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Risk Score: 0%"
                                android:textColor="#E0D6FF"
                                android:textSize="16sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Per-modality scores -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DETECTION BREAKDOWN"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <TextView android:id="@+id/tvBehaviorScore"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:layout_marginTop="14dp"
                            android:text="Behavior: —" />

                        <TextView android:id="@+id/tvChatScore"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:layout_marginTop="6dp"
                            android:text="Chat: —" />

                        <TextView android:id="@+id/tvVoiceScore"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:layout_marginTop="6dp"
                            android:text="Voice: —" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Observation note -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardObservationNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E3F2FD"
                    app:strokeWidth="0dp"
                    app:contentPadding="14dp">

                    <TextView
                        android:id="@+id/tvObservationNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0D47A1"
                        android:textSize="13sp"
                        android:text="" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Top risk factors -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTopFactors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:contentPadding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WHY THIS SCORE"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <TextView
                            android:id="@+id/tvTopFactors"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:layout_marginTop="10dp"
                            android:text="" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="24dp"
                    android:text="Back to dashboard"
                    app:icon="@drawable/ic_arrow_forward"
                    app:iconGravity="end"
                    app:iconTint="@color/colorOnPrimary" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
