# ─────────────────────────────────────────────────────────────────────────
# Backend environment — copy to `.env` and fill in. NEVER commit the real .env.
# In production these MUST be set; locally they fall back to insecure dev values.
# ─────────────────────────────────────────────────────────────────────────

# Secret used to sign bearer tokens. Set to a long random string in production.
# Changing it invalidates every issued token (forces re-login).
#   e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=

# Pepper for hashing PINs (keyed HMAC). Defaults to AUTH_SECRET if unset.
# Changing it invalidates all stored PIN hashes (users must reset PINs).
PIN_PEPPER=

# Token enforcement:
#   0 = shadow mode — verify tokens if present, log ownership violations, never reject
#       (use while rolling out / for the existing demo build)
#   1 = enforce — missing/invalid token -> 401, accessing another user's data -> 403
AUTH_ENFORCE=0

# Bearer token lifetime in seconds (default 30 days).
AUTH_TOKEN_TTL_SECONDS=2592000

# Keep uploaded voice WAVs after feature extraction (1/true) — TESTING ONLY.
# Leave unset/0 in production so raw audio is deleted immediately.
KEEP_AUDIO=0

# Target RMS the voice pipeline normalises audio to before emotion inference.
VOICE_RMS_TARGET=0.045

# Consent version string shown/recorded when a parent accepts monitoring. Bump it
# when the privacy terms change to re-prompt for consent.
CONSENT_VERSION=2026-05-30

# Auto-delete raw events (chat/voice/screen/notification) older than this many days,
# enforced on startup. 0 = keep indefinitely. Set e.g. 90 for a 90-day retention window.
DATA_RETENTION_DAYS=0
